PORT=8000
MONGO_URI=mongodb://127.0.0.1:27017/bee-luxury
JWT_SECRET=super_secret_bee_token_key_123
NODE_ENV=development

# Email Transporter Setup (Placeholders - NodeMailer will fallback to Ethereal / Local SMTP logs)
EMAIL_HOST=smtp.ethereal.email
EMAIL_PORT=587
EMAIL_USER=ethereal_user
EMAIL_PASS=ethereal_pass
EMAIL_FROM=no-reply@bee-luxury.com

# Cloudinary Setup (Placeholders - Node.js will fallback to Local Server Upload paths if keys are empty)
CLOUDINARY_CLOUD_NAME=mock_cloud
CLOUDINARY_API_KEY=mock_key
CLOUDINARY_API_SECRET=mock_secret
